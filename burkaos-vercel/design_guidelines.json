{
  "design_system": {
    "identity": {
      "name": "BurkaOS",
      "tagline": "Execution First. No Junk Volume.",
      "philosophy": "Mechanical Tension & Proximity to Failure. The interface is a tool, not a toy.",
      "archetype": "The Performance Pro (Archetype 2) - Tactical, High-Contrast, Precise."
    },
    "colors": {
      "palette": {
        "background": "#09090B",
        "surface": "#18181B",
        "surface_highlight": "#27272A",
        "primary": "#D4F46D",
        "primary_foreground": "#000000",
        "secondary": "#27272A",
        "secondary_foreground": "#FAFAFA",
        "muted": "#71717A",
        "border": "#27272A",
        "error": "#EF4444",
        "success": "#22C55E",
        "overlay": "rgba(0,0,0,0.8)"
      },
      "usage": {
        "screen_background": "background",
        "card_background": "surface",
        "primary_button": "primary",
        "primary_button_text": "primary_foreground",
        "heading_text": "secondary_foreground",
        "body_text": "muted",
        "border_color": "border"
      }
    },
    "typography": {
      "font_family": {
        "heading": "Oswald-Bold",
        "body": "System"
      },
      "sizes": {
        "xs": 12,
        "sm": 14,
        "base": 16,
        "lg": 18,
        "xl": 20,
        "2xl": 24,
        "3xl": 30,
        "4xl": 36,
        "5xl": 48
      },
      "weights": {
        "regular": "400",
        "medium": "500",
        "bold": "700",
        "black": "900"
      },
      "line_heights": {
        "tight": 1.1,
        "normal": 1.5,
        "relaxed": 1.75
      }
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 12,
      "lg": 16,
      "xl": 20,
      "2xl": 24,
      "3xl": 32,
      "4xl": 40,
      "section": 48
    },
    "borders": {
      "radius": {
        "sm": 8,
        "md": 12,
        "lg": 16,
        "xl": 24,
        "full": 9999
      },
      "width": {
        "hairline": 0.5,
        "thin": 1,
        "thick": 2
      }
    },
    "shadows": {
      "sm": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 1 },
        "shadowOpacity": 0.18,
        "shadowRadius": 1.0,
        "elevation": 1
      },
      "md": {
        "shadowColor": "#000",
        "shadowOffset": { "width": 0, "height": 2 },
        "shadowOpacity": 0.25,
        "shadowRadius": 3.84,
        "elevation": 5
      },
      "glow": {
        "shadowColor": "#D4F46D",
        "shadowOffset": { "width": 0, "height": 0 },
        "shadowOpacity": 0.3,
        "shadowRadius": 10,
        "elevation": 5
      }
    }
  },
  "components": {
    "Container": {
      "style": {
        "flex": 1,
        "backgroundColor": "#09090B",
        "paddingHorizontal": 20,
        "paddingTop": 60
      }
    },
    "Card": {
      "style": {
        "backgroundColor": "#18181B",
        "borderRadius": 16,
        "padding": 20,
        "marginBottom": 16,
        "borderWidth": 1,
        "borderColor": "#27272A"
      },
      "variants": {
        "active": {
          "borderColor": "#D4F46D",
          "backgroundColor": "#1C1C1E"
        }
      }
    },
    "Button": {
      "primary": {
        "height": 56,
        "backgroundColor": "#D4F46D",
        "borderRadius": 12,
        "justifyContent": "center",
        "alignItems": "center",
        "flexDirection": "row"
      },
      "secondary": {
        "height": 56,
        "backgroundColor": "#27272A",
        "borderRadius": 12,
        "justifyContent": "center",
        "alignItems": "center",
        "flexDirection": "row",
        "borderWidth": 1,
        "borderColor": "#3F3F46"
      },
      "ghost": {
        "height": 44,
        "backgroundColor": "transparent",
        "justifyContent": "center",
        "alignItems": "center"
      }
    },
    "Input": {
      "style": {
        "height": 56,
        "backgroundColor": "#18181B",
        "borderRadius": 12,
        "borderWidth": 1,
        "borderColor": "#27272A",
        "paddingHorizontal": 16,
        "color": "#FAFAFA",
        "fontSize": 16,
        "fontFamily": "System"
      },
      "focus": {
        "borderColor": "#D4F46D"
      }
    },
    "Typography": {
      "h1": {
        "fontSize": 36,
        "fontFamily": "Oswald-Bold",
        "color": "#FAFAFA",
        "letterSpacing": 0.5,
        "textTransform": "uppercase"
      },
      "h2": {
        "fontSize": 24,
        "fontFamily": "Oswald-Bold",
        "color": "#FAFAFA",
        "letterSpacing": 0.5,
        "marginBottom": 16
      },
      "body": {
        "fontSize": 16,
        "fontFamily": "System",
        "color": "#A1A1AA",
        "lineHeight": 24
      },
      "label": {
        "fontSize": 12,
        "fontFamily": "System",
        "color": "#71717A",
        "textTransform": "uppercase",
        "letterSpacing": 1.5,
        "fontWeight": "600"
      }
    }
  },
  "layout_strategies": {
    "dashboard_grid": {
      "type": "Bento Grid (Flexbox Implementation)",
      "gap": 16,
      "columns": 2
    },
    "workout_logger": {
      "focus": "One-Handed Use",
      "touch_target_min_height": 48,
      "input_alignment": "Right aligned for easy thumb reach",
      "keyboard_avoiding": true
    }
  },
  "assets": {
    "fonts": {
      "instructions": "Load Oswald-Bold and Oswald-Regular using expo-font. Use System font for body text for native feel.",
      "google_font_name": "Oswald"
    },
    "icons": {
      "library": "@expo/vector-icons",
      "preferred_set": "Lucide",
      "style": "Stroke width 2px, Size 24px default"
    },
    "images": {
      "hero_background": "https://images.unsplash.com/photo-1693214674451-2111f7690877?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NjAzMjd8MHwxfHNlYXJjaHwzfHxtb2Rlcm4lMjBkYXJrJTIwZ3ltJTIwaW50ZXJpb3IlMjBuZW9uJTIwYWVzdGhldGljfGVufDB8fHx8MTc3MjM0OTM0Mnww&ixlib=rb-4.1.0&q=85",
      "coach_avatar": "https://images.unsplash.com/photo-1754475172820-6053bbed3b25?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxODd8MHwxfHNlYXJjaHwxfHxtdXNjdWxhciUyMG1hbiUyMGZpdG5lc3MlMjBjb2FjaCUyMHBvcnRyYWl0JTIwZGFyayUyMGxpZ2h0aW5nfGVufDB8fHx8MTc3MjM0OTM0M3ww&ixlib=rb-4.1.0&q=85",
      "dumbbells_detail": "https://images.unsplash.com/photo-1638536534846-16e51e69a9b3?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxNzV8MHwxfHNlYXJjaHw0fHxoYXJkY29yZSUyMGd5bSUyMHdvcmtvdXQlMjBibGFjayUyMGFuZCUyMHdoaXRlfGVufDB8fHx8MTc3MjM0OTM0MXww&ixlib=rb-4.1.0&q=85",
      "barbell_plates": "https://images.unsplash.com/photo-1685633225377-50d1f1e01fee?crop=entropy&cs=srgb&fm=jpg&ixid=M3w4NTYxODl8MHwxfHNlYXJjaHwxfHxoYXJkY29yZSUyMGd5bSUyMHdvcmtvdXQlMjBibGFjayUyMGFuZCUyMHdoaXRlfGVufDB8fHx8MTc3MjM0OTM0NHww&ixlib=rb-4.1.0&q=85"
    }
  },
  "instructions_to_main_agent": [
    "Use StyleSheet.create() for all styling. DO NOT assume Tailwind is available.",
    "Create a 'constants/theme.js' file exporting the Colors, Spacing, and Typography objects defined above for reuse.",
    "Load fonts in the root layout (_layout.js) using expo-font hook.",
    "Ensure all TouchableOpacity elements have 'activeOpacity={0.7}' for tactile feedback.",
    "Use 'SafeAreaView' from 'react-native-safe-area-context' for all top-level screens.",
    "Implement Dark Mode by default. Force 'dark' in userInterfaceStyle in app.json if not already set.",
    "For lists, use 'FlashList' (if available) or 'FlatList'. Never use ScrollView for long lists.",
    "Add 'data-testid' props to all interactive elements for testing."
  ],
  "universal_guidelines": [
    "No gradients on text. Keep text high-contrast solid colors.",
    "Avoid centering text unless it is a very short headline. Left-align body text.",
    "Use 20px padding on screen edges. Do not let text touch the edges.",
    "Card backgrounds should be #18181B with a 1px #27272A border to separate from the #09090B background.",
    "Use the 'Electric Lime' (#D4F46D) sparingly for primary actions (Start Workout, Save) and active states."
  ]
}